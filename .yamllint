extends: default

rules:
  line-length:
    max: 160
    level: warning
  indentation:
    spaces: 2
    indent-sequences: true
  truthy:
    allowed-values: ["true", "false", "on", "off", "yes", "no"]
    check-keys: false
  document-start: disable

ignore: |
  dbt_packages/
  target/
  .venv/
  package-lock.yml
  profiles/.user.yml
  .github/
